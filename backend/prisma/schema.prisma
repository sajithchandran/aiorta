generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  INDIVIDUAL
  TEAM
  ORGANIZATION

  @@map("tenant_type")
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED

  @@map("membership_status")
}

enum RoleScope {
  GLOBAL
  TENANT
  PROJECT

  @@map("role_scope")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  CLOSED

  @@map("project_status")
}

enum DocumentType {
  PROTOCOL
  SAP
  IRB_LETTER
  DATA_DICTIONARY
  CONSENT_TEMPLATE
  MANUSCRIPT_ATTACHMENT
  OTHER

  @@map("document_type")
}

enum DataSourceType {
  CSV_UPLOAD
  EXCEL_UPLOAD
  MANUAL_ENTRY
  FHIR
  DATABASE
  OTHER

  @@map("data_source_type")
}

enum DataSourceStatus {
  PENDING
  READY
  FAILED
  ARCHIVED

  @@map("data_source_status")
}

enum DatasetStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("dataset_status")
}

enum DatasetVersionStatus {
  BUILDING
  READY
  APPROVED
  SUPERSEDED
  RETIRED
  FAILED

  @@map("dataset_version_status")
}

enum CohortStatus {
  DRAFT
  SNAPSHOTTED
  ARCHIVED

  @@map("cohort_status")
}

enum CohortRuleNodeType {
  GROUP
  CONDITION

  @@map("cohort_rule_node_type")
}

enum LogicalOperator {
  AND
  OR

  @@map("logical_operator")
}

enum ComparisonOperator {
  EQ
  NEQ
  GT
  GTE
  LT
  LTE
  IN
  NOT_IN
  BETWEEN
  EXISTS
  NOT_EXISTS
  CONTAINS
  STARTS_WITH
  ENDS_WITH
  DATE_WITHIN

  @@map("comparison_operator")
}

enum DerivedVariableType {
  NUMERIC
  CATEGORICAL
  BOOLEAN
  DATE
  TEXT

  @@map("derived_variable_type")
}

enum StatisticalPlanStatus {
  DRAFT
  APPROVED
  ARCHIVED

  @@map("statistical_plan_status")
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  APPROVED

  @@map("analysis_run_status")
}

enum AnalysisResultType {
  SUMMARY
  DESCRIPTIVE
  GROUP_COMPARISON
  REGRESSION
  SURVIVAL
  SENSITIVITY
  OTHER

  @@map("analysis_result_type")
}

enum ArtifactStatus {
  DRAFT
  APPROVED
  SUPERSEDED
  ARCHIVED

  @@map("artifact_status")
}

enum ManuscriptStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  EXPORTED
  ARCHIVED

  @@map("manuscript_status")
}

enum ManuscriptVersionStatus {
  DRAFT
  IN_REVIEW
  APPROVED_FOR_EXPORT
  EXPORTED
  SUPERSEDED

  @@map("manuscript_version_status")
}

enum ManuscriptSectionType {
  TITLE
  ABSTRACT
  INTRODUCTION
  METHODS
  RESULTS
  DISCUSSION
  REFERENCES
  SUPPLEMENT

  @@map("manuscript_section_type")
}

enum ReferenceType {
  JOURNAL
  BOOK
  WEBSITE
  GUIDELINE
  PREPRINT
  OTHER

  @@map("reference_type")
}

enum AIJobType {
  OUTLINE
  METHODS_DRAFT
  RESULTS_DRAFT
  DISCUSSION_DRAFT
  TABLE_NARRATIVE
  REVISION_ASSIST

  @@map("ai_job_type")
}

enum AIJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED

  @@map("ai_job_status")
}

enum AIOutputStatus {
  DRAFT
  VALIDATION_FAILED
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED

  @@map("ai_output_status")
}

enum AIReviewDecision {
  APPROVED
  REJECTED
  NEEDS_CHANGES

  @@map("ai_review_decision")
}

enum ApprovalTargetType {
  DATASET_VERSION
  ANALYSIS_RUN
  ANALYSIS_RESULT
  RESULT_TABLE
  RESULT_FIGURE
  AI_OUTPUT
  MANUSCRIPT_VERSION
  IRB_SUBMISSION
  PROTOCOL

  @@map("approval_target_type")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED

  @@map("approval_status")
}

enum SignatureStatus {
  PENDING
  SIGNED
  REVOKED

  @@map("signature_status")
}

enum IRBSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED

  @@map("irb_submission_status")
}

enum AuditOutcome {
  SUCCESS
  FAILURE

  @@map("audit_outcome")
}

enum AccessAction {
  VIEW
  DOWNLOAD
  EXPORT
  API_READ
  API_WRITE

  @@map("access_action")
}

enum AccessOutcome {
  ALLOWED
  DENIED

  @@map("access_outcome")
}

model User {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String?           @map("tenant_id") @db.Uuid
  createdById    String?           @map("created_by_id") @db.Uuid
  email          String            @unique
  fullName       String            @map("full_name")
  passwordHash   String?           @map("password_hash")
  isActive       Boolean           @default(true) @map("is_active")
  lastLoginAt    DateTime?         @map("last_login_at") @db.Timestamptz(6)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)
  memberships    TenantMembership[]
  projectMembers ProjectMember[]

  @@index([tenantId, deletedAt])
  @@index([createdById])
  @@map("user")
}

model Tenant {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @unique @map("tenant_id") @db.Uuid
  createdById  String             @map("created_by_id") @db.Uuid
  name         String
  slug         String             @unique
  type         TenantType
  isActive     Boolean            @default(true) @map("is_active")
  metadataJson Json?              @map("metadata_json")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?          @map("deleted_at") @db.Timestamptz(6)
  memberships  TenantMembership[]
  projects     Project[]

  @@index([type, deletedAt])
  @@map("tenant")
}

model TenantMembership {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  createdById String           @map("created_by_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  roleId      String           @map("role_id") @db.Uuid
  status      MembershipStatus @default(INVITED)
  invitedAt   DateTime?        @map("invited_at") @db.Timestamptz(6)
  joinedAt    DateTime?        @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz(6)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user        User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  role        Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([tenantId, userId, deletedAt])
  @@index([userId, status])
  @@index([roleId])
  @@map("tenant_membership")
}

model Role {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String?            @map("tenant_id") @db.Uuid
  createdById     String?            @map("created_by_id") @db.Uuid
  name            String
  key             String             @unique
  scope           RoleScope
  isSystem        Boolean            @default(false) @map("is_system")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  tenantMembers   TenantMembership[]
  projectMembers  ProjectMember[]

  @@index([tenantId, scope, deletedAt])
  @@map("role")
}

model Permission {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String?            @map("tenant_id") @db.Uuid
  createdById     String?            @map("created_by_id") @db.Uuid
  key             String             @unique
  name            String
  description     String?
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@index([tenantId, deletedAt])
  @@map("permission")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String?    @map("tenant_id") @db.Uuid
  createdById  String?    @map("created_by_id") @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([tenantId, deletedAt])
  @@map("role_permission")
}

model Project {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  createdById      String            @map("created_by_id") @db.Uuid
  title            String
  code             String?
  slug             String
  description      String?
  status           ProjectStatus     @default(DRAFT)
  startsAt         DateTime?         @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime?         @map("ends_at") @db.Timestamptz(6)
  metadataJson     Json?             @map("metadata_json")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz(6)
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  members          ProjectMember[]
  protocols        Protocol[]
  studyDocuments   StudyDocument[]
  dataSources      DataSource[]
  datasets         Dataset[]
  datasetVersions  DatasetVersion[]
  cohorts          Cohort[]
  statisticalPlans StatisticalPlan[]
  analysisRuns     AnalysisRun[]
  manuscripts      Manuscript[]
  aiJobs           AIJob[]
  approvals        Approval[]
  irbSubmissions   IRBSubmission[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, deletedAt])
  @@index([createdById])
  @@map("project")
}

model ProjectMember {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  createdById String    @map("created_by_id") @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  roleId      String    @map("role_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  user        User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([tenantId, projectId, deletedAt])
  @@index([userId, deletedAt])
  @@index([roleId])
  @@map("project_member")
}

model Protocol {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  createdById    String         @map("created_by_id") @db.Uuid
  projectId      String         @map("project_id") @db.Uuid
  version        Int
  title          String
  synopsis       String?
  status         ApprovalStatus @default(PENDING)
  documentPath   String?        @map("document_path")
  checksum       String?
  metadataJson   Json?          @map("metadata_json")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  irbSubmissions IRBSubmission[]

  @@unique([projectId, version])
  @@index([tenantId, projectId, deletedAt])
  @@map("protocol")
}

model StudyDocument {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  createdById   String       @map("created_by_id") @db.Uuid
  projectId     String       @map("project_id") @db.Uuid
  documentType  DocumentType @map("document_type")
  title         String
  storagePath   String       @map("storage_path")
  mimeType      String?      @map("mime_type")
  fileSizeBytes BigInt?      @map("file_size_bytes")
  checksum      String?
  metadataJson  Json?        @map("metadata_json")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([tenantId, projectId, documentType, deletedAt])
  @@map("study_document")
}

model DataSource {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  createdById     String           @map("created_by_id") @db.Uuid
  projectId       String           @map("project_id") @db.Uuid
  name            String
  type            DataSourceType
  status          DataSourceStatus @default(PENDING)
  sourceUri       String?          @map("source_uri")
  storagePath     String?          @map("storage_path")
  checksum        String?
  contentType     String?          @map("content_type")
  rowCount        Int?             @map("row_count")
  metadataJson    Json?            @map("metadata_json")
  ingestedAt      DateTime?        @map("ingested_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  datasets        Dataset[]
  datasetVersions DatasetVersion[]
  cohorts         Cohort[]

  @@index([tenantId, projectId, status, deletedAt])
  @@map("data_source")
}

model Dataset {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  createdById      String           @map("created_by_id") @db.Uuid
  projectId        String           @map("project_id") @db.Uuid
  dataSourceId     String?          @map("data_source_id") @db.Uuid
  name             String
  description      String?
  status           DatasetStatus    @default(DRAFT)
  metadataJson     Json?            @map("metadata_json")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  dataSource       DataSource?      @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  versions         DatasetVersion[]
  derivedVariables DerivedVariable[]

  @@index([tenantId, projectId, status, deletedAt])
  @@map("dataset")
}

model DatasetVersion {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  createdById     String               @map("created_by_id") @db.Uuid
  projectId       String               @map("project_id") @db.Uuid
  datasetId       String               @map("dataset_id") @db.Uuid
  dataSourceId    String?              @map("data_source_id") @db.Uuid
  cohortId        String?              @map("cohort_id") @db.Uuid
  parentVersionId String?              @map("parent_version_id") @db.Uuid
  versionNumber   Int                  @map("version_number")
  status          DatasetVersionStatus @default(BUILDING)
  isImmutable     Boolean              @default(true) @map("is_immutable")
  rowCount        Int?                 @map("row_count")
  columnCount     Int?                 @map("column_count")
  schemaHash      String?              @map("schema_hash")
  contentChecksum String?              @map("content_checksum")
  storagePath     String?              @map("storage_path")
  manifestJson    Json?                @map("manifest_json")
  lineageJson     Json?                @map("lineage_json")
  approvedAt      DateTime?            @map("approved_at") @db.Timestamptz(6)
  approvedById    String?              @map("approved_by_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?            @map("deleted_at") @db.Timestamptz(6)
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Restrict)
  dataset         Dataset              @relation(fields: [datasetId], references: [id], onDelete: Restrict)
  dataSource      DataSource?          @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  cohort          Cohort?              @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  parentVersion   DatasetVersion?      @relation("DatasetVersionLineage", fields: [parentVersionId], references: [id], onDelete: SetNull)
  childVersions   DatasetVersion[]     @relation("DatasetVersionLineage")
  analysisRuns    AnalysisRun[]
  aiJobs          AIJob[]
  aiOutputs       AIOutput[]

  @@unique([datasetId, versionNumber])
  @@index([tenantId, projectId, status, deletedAt])
  @@index([contentChecksum])
  @@index([cohortId])
  @@map("dataset_version")
}

model Cohort {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  createdById     String       @map("created_by_id") @db.Uuid
  projectId       String       @map("project_id") @db.Uuid
  dataSourceId    String?      @map("data_source_id") @db.Uuid
  name            String
  description     String?
  status          CohortStatus @default(DRAFT)
  versionNumber   Int          @default(1) @map("version_number")
  snapshotAt      DateTime?    @map("snapshot_at") @db.Timestamptz(6)
  subjectCount    Int?         @map("subject_count")
  metadataJson    Json?        @map("metadata_json")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  dataSource      DataSource?  @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  rules           CohortRule[]
  datasetVersions DatasetVersion[]

  @@index([tenantId, projectId, status, deletedAt])
  @@map("cohort")
}

model CohortRule {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  createdById     String             @map("created_by_id") @db.Uuid
  cohortId        String             @map("cohort_id") @db.Uuid
  parentRuleId    String?            @map("parent_rule_id") @db.Uuid
  nodeType        CohortRuleNodeType @map("node_type")
  logicalOperator LogicalOperator?   @map("logical_operator")
  fieldKey        String?            @map("field_key")
  fieldLabel      String?            @map("field_label")
  operator        ComparisonOperator?
  valueJson       Json?              @map("value_json")
  sortOrder       Int                @default(0) @map("sort_order")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz(6)
  cohort          Cohort             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  parentRule      CohortRule?        @relation("CohortRuleTree", fields: [parentRuleId], references: [id], onDelete: Cascade)
  childRules      CohortRule[]       @relation("CohortRuleTree")

  @@index([tenantId, cohortId, deletedAt])
  @@index([parentRuleId, sortOrder])
  @@map("cohort_rule")
}

model DerivedVariable {
  id                     String              @id @default(uuid()) @db.Uuid
  tenantId               String              @map("tenant_id") @db.Uuid
  createdById            String              @map("created_by_id") @db.Uuid
  projectId              String              @map("project_id") @db.Uuid
  datasetId              String              @map("dataset_id") @db.Uuid
  sourceDatasetVersionId String?             @map("source_dataset_version_id") @db.Uuid
  name                   String
  label                  String?
  type                   DerivedVariableType
  expression             String
  definitionJson         Json?               @map("definition_json")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?           @map("deleted_at") @db.Timestamptz(6)
  dataset                Dataset             @relation(fields: [datasetId], references: [id], onDelete: Restrict)

  @@index([tenantId, projectId, deletedAt])
  @@index([datasetId, deletedAt])
  @@map("derived_variable")
}

model StatisticalPlan {
  id           String                @id @default(uuid()) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  createdById  String                @map("created_by_id") @db.Uuid
  projectId    String                @map("project_id") @db.Uuid
  name         String
  version      Int                   @default(1)
  status       StatisticalPlanStatus @default(DRAFT)
  planJson     Json                  @map("plan_json")
  checksum     String?
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?             @map("deleted_at") @db.Timestamptz(6)
  project      Project               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  analysisRuns AnalysisRun[]

  @@unique([projectId, name, version])
  @@index([tenantId, projectId, status, deletedAt])
  @@map("statistical_plan")
}

model AnalysisRun {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  createdById       String            @map("created_by_id") @db.Uuid
  projectId         String            @map("project_id") @db.Uuid
  datasetVersionId  String            @map("dataset_version_id") @db.Uuid
  statisticalPlanId String?           @map("statistical_plan_id") @db.Uuid

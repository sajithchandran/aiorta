{
  "name": "@aiorta/backend",
  "private": true,
  "version": "0.1.0",
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "devDependencies": {
    "prisma": "6.19.2"
  },
  "scripts": {
    "install:workspace": "pnpm install",
    "prisma:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 ./services/api/node_modules/.bin/prisma generate --schema prisma/schema.prisma",
    "build": "pnpm --filter @aiorta/api build",
    "build:api": "pnpm --filter @aiorta/api build",
    "typecheck": "pnpm --filter @aiorta/api typecheck",
    "typecheck:api": "pnpm --filter @aiorta/api typecheck",
    "dev:api": "pnpm --filter @aiorta/api start:dev"
  }
}
